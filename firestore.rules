rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user private data: inventory, color notes, patterns, pattern colors,
    // grid configs, progress. Each user can only read/write their own subtree.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
